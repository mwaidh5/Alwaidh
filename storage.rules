rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function emailVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    // Role lists live in Firestore settings/site — same source the app and
    // Firestore rules use, read here via cross-service rules.
    function settingsData() {
      return firestore.get(/databases/(default)/documents/settings/site).data;
    }
    function isOwner() {
      return emailVerified() && request.auth.token.email == 'mwaidh5@gmail.com';
    }
    function isAdmin() {
      return isOwner()
        || (emailVerified()
            && request.auth.token.email in settingsData().get('extraAdminEmails', []));
    }
    function isComputerStaff() {
      return emailVerified()
        && request.auth.token.email in settingsData().get('computerStaffEmails', []);
    }
    function isSolarStaff() {
      return emailVerified()
        && request.auth.token.email in settingsData().get('solarStaffEmails', []);
    }

    // Public read for anything customers might see (product images, etc).
    match /{allPaths=**} {
      allow read: if true;
    }

    // Product images: admins and product staff (either team).
    match /products/{allPaths=**} {
      allow write: if isAdmin() || isComputerStaff() || isSolarStaff();
    }

    // Site images (hero, banners, logo): admin only.
    match /site/{allPaths=**} {
      allow write: if isAdmin();
    }

    // Job invoices (PDFs): admins and solar staff.
    match /jobs/{allPaths=**} {
      allow write: if isAdmin() || isSolarStaff();
    }

    // Per-user uploads: any signed-in user can write under their own uid.
    match /uploads/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
