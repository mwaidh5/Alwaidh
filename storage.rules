rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Public read for anything customers might see (product images, etc).
    match /{allPaths=**} {
      allow read: if true;
    }

    // Product images: only admins can write/replace/delete.
    match /products/{allPaths=**} {
      allow write: if isAdmin();
    }

    // Site images (hero, banners, logo) and project photos: admin only.
    match /site/{allPaths=**} {
      allow write: if isAdmin();
    }
    match /projects/{allPaths=**} {
      allow write: if isAdmin();
    }

    // Per-user uploads: any signed-in user can write under their own uid.
    match /uploads/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email_verified == true &&
        request.auth.token.email in [
          'mwaidh5@gmail.com'
        ];
    }
  }
}
